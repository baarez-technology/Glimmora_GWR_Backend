# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────
# SQLite (local dev, no install needed):
DATABASE_URL=sqlite+aiosqlite:///./gwr_dev.db

# PostgreSQL (production / pgvector):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gwr

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AWS S3 (leave blank to use local filesystem storage) ─────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=gwr-evidence

# ── SendGrid ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@glimmora.com

# ── Twilio ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Sentry ───────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Magic link ───────────────────────────────────────────────────────
MAGIC_LINK_EXPIRE_HOURS=72
FRONTEND_URL=http://localhost:5173
